{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role and access details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "enrolledCourses": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "Course information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string" },
        "lessons": { "type": "array", "items": { "type": "string" } },
        "whatsappMessage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "category"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "Student enrollment request and proof of payment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentUid": { "type": "string" },
        "studentEmail": { "type": "string" },
        "studentName": { "type": "string" },
        "studentPhone": { "type": "string" },
        "courseId": { "type": "string" },
        "courseTitle": { "type": "string" },
        "transactionId": { "type": "string" },
        "proofImage": { "type": "string", "description": "Base64 encoded image" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "rejectionReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentUid", "courseId", "transactionId", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Available courses"
    },
    "/enrollments/{enrollmentId}": {
      "schema": "Enrollment",
      "description": "Enrollment requests"
    }
  }
}
